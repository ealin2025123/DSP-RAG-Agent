# Copy this file to .env and fill keys locally. Never commit .env.
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_WORKSPACE_ID=
LYY_KB_PATH=
# Optional explicit endpoints if your region or workspace uses custom URLs.
DASHSCOPE_EMBEDDING_BASE_URL=
DASHSCOPE_RERANK_BASE_URL=
QWEN_MODEL=qwen3-max
DEEPSEEK_MODEL=deepseek-v4-flash

# Set to 1 to force local retrieval without any external model call.
LYY_OFFLINE=0

# Optional LangSmith tracing. Leave false/empty for normal local use.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=LYY-DSP-RAG-Agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
